# ============================================
# convergio-mesh — Environment Variables
# ============================================

# --- Authentication (required) ---
# Auth token for mesh node authentication
CONVERGIO_AUTH_TOKEN=your-auth-token-here

# --- Mesh Networking ---
# Local Tailscale IP for mesh networking
# CONVERGIO_LOCAL_TAILSCALE_IP=100.x.x.x

# Role of this node in the mesh (e.g., leader, worker)
# CONVERGIO_NODE_ROLE=worker

# Path to peers configuration file
# CONVERGIO_PEERS_CONF=/path/to/peers.toml

# --- Sync ---
# Sync interval in seconds
# CONVERGIO_SYNC_INTERVAL_SECS=30

# Enable/disable repository sync (true/false)
# CONVERGIO_SYNC_REPO_ENABLED=true
